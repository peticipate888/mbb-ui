{
  "name": "@peticipate/mbb-ui",
  "version": "1.1.0",
  "description": "毛幫幫 (Peticipate) Design System — React component library with full color system, dynamic effects, accessibility, and bundled visual assets.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/mbb-design-system.css",
    "./styles/globals.css": "./dist/mbb-design-system.css",
    "./tailwind": "./dist/tailwind-preset.js",
    "./assets": {
      "import": "./dist/assets/index.mjs",
      "require": "./dist/assets/index.js",
      "types": "./dist/assets/index.d.ts"
    },
    "./assets/*": "./dist/assets/*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "next": ">=14.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.0.0",
    "aos": "^2.3.4"
  },
  "devDependencies": {
    "@types/aos": "^3.0.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "tailwindcss": "^4.0.0"
  },
  "keywords": ["mbb", "peticipate", "毛幫幫", "design-system", "react", "components", "tailwindcss"],
  "repository": {
    "type": "git",
    "url": "https://github.com/peticipate/mbb-ui.git"
  },
  "license": "MIT",
  "author": "Peticipate <dev@mbb.pet>"
}
